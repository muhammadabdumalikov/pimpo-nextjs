# Copy to .env.local and adjust as needed.

# Base URL of the pimpo backend API.
# NOTE: NEXT_PUBLIC_* values are inlined at build time and used by the browser,
# so this must be a URL reachable from the user's browser (not "postgres" or a
# docker-internal hostname). For Docker builds, pass it as a --build-arg.
NEXT_PUBLIC_API_URL=http://localhost:3050
